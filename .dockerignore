# Git
.git/
.gitignore

# Datos locales (se montan como volumen en runtime, no van en la imagen)
data/

# Salidas (se generan en runtime, montadas como volumen)
artifacts/
logs/
reports/

# Legacy del modo file:// (ya no se usa, pero lo excluimos por si quedo en disco)
mlruns/

# Notebooks y experimentacion
notebooks/

# Cache Python
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo

# Tests y caches de tooling (no van a la imagen de runtime)
tests/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Entornos virtuales
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# Variables de entorno locales (NUNCA en la imagen)
.env
.env.*
!.env.example

# Archivos temporales
*.log
*.tmp
