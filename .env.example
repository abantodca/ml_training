# Variables de entorno consumidas por Taskfile + el codigo.
# Copia a `.env` y rellena. NO comitear `.env`.

# ---------- AWS / S3 ----------
AWS_REGION=us-east-1
S3_BUCKET=ml-poc-training-data

# ---------- SSH a las EC2 ----------
# Path al .pem usado al crear el key pair de Terraform
SSH_KEY=~/.ssh/ml-training.pem

# Hosts publicos de las EC2 (los rellenas DESPUES de `task infra:apply`
# copiando los outputs de Terraform):
TRAINING_HOST=ec2-X-Y-Z-W.compute-1.amazonaws.com
MLFLOW_HOST=ec2-A-B-C-D.compute-1.amazonaws.com

# ---------- MLflow ----------
# El training apuntara a este URI (la EC2 de training lo usa).
# IMPORTANTE: dotenv NO expande variables; pon el host literal:
#   MLFLOW_TRACKING_URI=http://12.34.56.78:5000
MLFLOW_TRACKING_URI=http://EC2_MLFLOW_PUBLIC_IP:5000
# El experimento real es prefix + variety (ej. 'productivity_POP'); cada
# variedad tiene su propio experimento en MLflow.
MLFLOW_EXPERIMENT_PREFIX=productivity_
MODEL_REGISTRY_PREFIX=productivity_

# ---------- Python interpreter (override en EC2 al venv) ----------
# Local: deja que task use el `python` del PATH (ideal con venv activo).
# EC2:   `cloud-init` sobrescribe este valor a /opt/ml_training/venv/bin/python
PYTHON=python

# ---------- Lambda power manager (lo dice `task infra:output`) ----------
LAMBDA_POWER_NAME=ml-training-power-manager
