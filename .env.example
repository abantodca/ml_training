# Variables de entorno para el Taskfile + el codigo.
# Copia a `.env`. Las marcadas REQUIRED son obligatorias: sin ellas
# `task up` falla al arranque de Docker compose.

# ---------- AWS (sin secrets) ----------
# Las credenciales VIVEN EN ~/.aws/credentials del host (creadas con
# `aws configure`). docker-compose monta ~/.aws como :ro en los containers
# y el AWS SDK las lee desde ahi via AWS_PROFILE + AWS_SHARED_CREDENTIALS_FILE.
# Asi NO hay que duplicar secretos en .env.
#
# AWS_PROFILE: nombre del profile en ~/.aws/credentials (default: 'default').
#   Si solo corriste `aws configure` sin --profile, dejar el default.
# AWS_DEFAULT_REGION: la region donde existen los buckets.
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1

# ---------- Buckets S3 (REQUIRED) ----------
# Deben existir antes de `task up`. Crearlos con:
#   aws s3 mb s3://<nombre> --region us-east-1
# (o seguir GUIA_MLOPS_AWS.md §3 para versioning / encryption / lifecycle).
#
# S3_MLFLOW_BUCKET   = bucket donde MLflow server pone artifacts de runs
#                      (modelos, plots, signatures). MLflow lo usa como
#                      `--default-artifact-root s3://<bucket>/artifacts`.
# S3_ARTIFACTS_BUCKET = bucket donde el trainer sube artifacts/ y reports/
#                      al final del run via scripts/s3_sync.py.
# Pueden ser el mismo bucket si no necesitas politicas IAM separadas.
S3_MLFLOW_BUCKET=cabanto-ml-mlflow
S3_ARTIFACTS_BUCKET=cabanto-ml-artifacts

# ---------- Python interpreter (opcional) ----------
# Por default el Taskfile usa `python` del PATH. Override si tu venv vive
# en otra ruta.
# PYTHON=/path/a/tu/venv/bin/python

# ---------- MLflow (opcional) ----------
# URI del tracking server. Default config.py = http://localhost:5000
# (apunta al servicio Docker expuesto al host). Adentro del container del
# trainer se sobreescribe a http://mlflow:5000 via docker-compose.yml.
# Override solo si corres scripts en el host contra otro server.
# MLFLOW_TRACKING_URI=http://localhost:5000

# Prefijo para nombres de experimentos en MLflow. Default = "" (cada
# variedad crea su propio experimento con su nombre, ej. "POP").
# MLFLOW_EXPERIMENT_PREFIX=

# Prefijo para registered models en el Model Registry. Default ya tiene
# valor sano en config.py ("rnd-forest-"), no es necesario override.
# MODEL_REGISTRY_PREFIX=rnd-forest-

# ---------- Reporte gerencial (HTML) ----------
# Plotly inline (1, default) hace el HTML autocontenido (~+4.5MB);
# CDN (0) deja el HTML chico pero requiere internet para renderizar charts.
# REPORT_PLOTLY_OFFLINE=1
